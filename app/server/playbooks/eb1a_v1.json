{
  "playbook_id": "eb1a_v1",
  "version": "1.0.0",
  "case_type": "eb1a",
  "jurisdiction": "US-Federal",
  "language_variants": ["en", "zh"],
  "audience": "law_firm_internal",
  "description": "EB-1A Extraordinary Ability intake playbook. Covers self-petitioning or employer-sponsored I-140, concurrent AOS, and consular processing.",
  
  "scenarios": {
    "I140_Only": {
      "label": "I-140 Petition Only",
      "resolve_when": {
        "beneficiary_location": "abroad",
        "filing_strategy": "i140_only"
      },
      "forms": ["I-140", "ETA-750B_or_Statement"],
      "notes": "Premium processing available. Consular processing follows approval."
    },
    "Concurrent_AOS": {
      "label": "Concurrent I-140 & I-485 (Adjustment of Status)",
      "resolve_when": {
        "beneficiary_location": "inside_us",
        "beneficiary_lawful_entry": true
      },
      "forms": ["I-140", "I-485", "I-765", "I-131", "I-693"],
      "notes": "Priority date must be current for EB-1 to file concurrently."
    },
    "Consular_DS260": {
      "label": "Consular Processing (Post I-140 Approval)",
      "resolve_when": {
        "beneficiary_location": "abroad",
        "filing_strategy": "consular"
      },
      "forms": ["DS-260", "civil_documents_package"],
      "notes": "After I-140 approval, NVC processing."
    }
  },

  "required_facts": [
    { "id": "beneficiary_identity", "label": "Beneficiary full legal name & DOB", "type": "entity", "required": true, "priority": 1, "confirm_by_human": false, "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] },
    { "id": "beneficiary_location", "label": "Beneficiary currently inside U.S. or abroad", "type": "enum", "values": ["inside_us", "abroad"], "required": true, "priority": 1, "confirm_by_human": true, "scenario_resolver": true, "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] },
    { "id": "filing_strategy", "label": "Filing strategy (i140_only vs concurrent vs consular)", "type": "enum", "values": ["i140_only", "concurrent", "consular"], "required": true, "priority": 1, "confirm_by_human": true, "scenario_resolver": true, "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] },
    { "id": "field_of_endeavor", "label": "Area of extraordinary ability", "type": "string", "required": true, "priority": 1, "confirm_by_human": true, "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] },
    { "id": "intent_to_continue_work", "label": "Intent to continue working in area of expertise", "type": "boolean", "required": true, "priority": 2, "confirm_by_human": true, "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] },
    { "id": "sustained_acclaim_summary", "label": "Summary of sustained national/international acclaim", "type": "string", "required": true, "priority": 2, "confirm_by_human": false, "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] },
    { "id": "beneficiary_lawful_entry", "label": "Was last entry lawful / inspected", "type": "boolean", "required": true, "priority": 2, "confirm_by_human": true, "scenario_resolver": true, "applies_to": ["Concurrent_AOS"] },
    { "id": "beneficiary_entry_record", "label": "Beneficiary most recent entry: date, place, manner (I-94 / inspection)", "type": "structured", "required": true, "priority": 2, "confirm_by_human": true, "applies_to": ["Concurrent_AOS"] },
    { "id": "immigration_history", "label": "Overstay, prior denials, removal/deportation, unlawful presence", "type": "structured", "required": true, "priority": 2, "confirm_by_human": true, "checked_for": ["immigration_risk"], "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] },
    { "id": "criminal_history", "label": "Any arrests or convictions", "type": "structured", "required": true, "priority": 2, "confirm_by_human": true, "checked_for": ["criminal_risk"], "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] }
  ],

  "required_documents": {
    "identity": [
      { "id": "beneficiary_passport", "label": "Beneficiary passport biographic page", "required": true, "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] },
      { "id": "statement_of_intent", "label": "Statement detailing plans to continue work in area of expertise", "required": true, "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"] }
    ],
    "entry_status": [
      { "id": "i94_record", "label": "I-94 / entry record", "required": true, "applies_to": ["Concurrent_AOS"] },
      { "id": "current_visa_or_status_doc", "label": "Current visa / status document", "required": false, "applies_to": ["Concurrent_AOS"] }
    ],
    "medical": [
      { "id": "i693_medical", "label": "I-693 medical exam (civil surgeon)", "required": true, "applies_to": ["Concurrent_AOS"] }
    ]
  },

  "evidence_map": {
    "eb1a_criteria": {
      "label": "Extraordinary Ability Criteria (10 regulatory criteria)",
      "min_items": 3,
      "weight": "critical",
      "preferred": [
        { "id": "awards_prizes", "strength": "high" },
        { "id": "memberships_elite", "strength": "high" },
        { "id": "published_material_about_applicant", "strength": "high" },
        { "id": "judging_others", "strength": "high" },
        { "id": "original_contributions", "strength": "high" },
        { "id": "scholarly_articles", "strength": "high" },
        { "id": "exhibitions_showcases", "strength": "medium" },
        { "id": "leading_critical_role", "strength": "high" },
        { "id": "high_salary", "strength": "medium" },
        { "id": "commercial_successes_arts", "strength": "medium" }
      ],
      "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"]
    },
    "sustained_acclaim": {
      "label": "Sustained Acclaim & Impact",
      "min_items": 2,
      "weight": "high",
      "preferred": [
        { "id": "expert_reference_letters", "strength": "high" },
        { "id": "citation_record", "strength": "high" },
        { "id": "media_coverage", "strength": "medium" }
      ],
      "applies_to": ["I140_Only", "Concurrent_AOS", "Consular_DS260"]
    }
  },

  "escalation_flags": [
    {
      "id": "criteria_weak",
      "label": "Fewer than 3 extraordinary ability criteria met",
      "trigger": { "evidence_category": "eb1a_criteria", "condition": "count_lt_min_items" },
      "severity": "high",
      "action": "block_petition_assembly",
      "message": "Fewer than 3 statutory criteria identified. EB-1A requires at least 3, or a major one-time achievement."
    },
    {
      "id": "acclaim_weak",
      "label": "Weak evidence of sustained acclaim",
      "trigger": { "evidence_category": "sustained_acclaim", "condition": "count_lt_min_items" },
      "severity": "info",
      "action": "notify_attorney",
      "message": "Limited independent evidence (letters, citations) of sustained national/international acclaim."
    },
    {
      "id": "criminal_risk",
      "label": "Criminal history present",
      "trigger": { "fact": "criminal_history", "condition": "is_present" },
      "severity": "critical",
      "action": "attorney_review_required",
      "message": "Criminal history present. Requires attorney admissibility assessment."
    },
    {
      "id": "immigration_risk",
      "label": "Adverse immigration history",
      "trigger": { "fact": "immigration_history", "condition": "any_adverse_present" },
      "severity": "critical",
      "action": "attorney_review_required",
      "message": "Adverse immigration history present. Assess inadmissibility bars."
    },
    {
      "id": "unlawful_entry_aos_bar",
      "label": "AOS may be barred by unlawful entry",
      "trigger": { "fact": "beneficiary_lawful_entry", "condition": "is_false", "and_scenario_in": ["Concurrent_AOS"] },
      "severity": "critical",
      "action": "attorney_review_required",
      "message": "Last entry without inspection. AOS likely unavailable for EB-1A."
    }
  ],

  "scoring": {
    "method": "weighted_dimensions_with_penalties",
    "dimensions": [
      {
        "id": "identity",
        "label": "Identity & Intent",
        "weight": 0.20,
        "components": [
          { "type": "facts_present", "facts": ["beneficiary_identity", "field_of_endeavor", "intent_to_continue_work"], "share": 0.5 },
          { "type": "documents_present", "docs": ["beneficiary_passport", "statement_of_intent"], "share": 0.5 }
        ]
      },
      {
        "id": "criteria",
        "label": "Extraordinary Ability Criteria",
        "weight": 0.40,
        "components": [
          { "type": "evidence_threshold", "category": "eb1a_criteria", "share": 1.0 }
        ]
      },
      {
        "id": "acclaim",
        "label": "Sustained Acclaim & Impact",
        "weight": 0.20,
        "components": [
          { "type": "evidence_threshold", "category": "sustained_acclaim", "share": 1.0 }
        ]
      },
      {
        "id": "admissibility",
        "label": "Admissibility & Status",
        "weight": 0.20,
        "components": [
          { "type": "facts_present", "facts": ["beneficiary_entry_record", "immigration_history", "criminal_history"], "share": 0.6 },
          { "type": "documents_present", "docs": ["i94_record"], "share": 0.4 }
        ]
      }
    ],
    "penalties": [
      { "flag": "criteria_weak", "deduct": 20 },
      { "flag": "acclaim_weak", "deduct": 10 },
      { "flag": "criminal_risk", "deduct": 10 },
      { "flag": "immigration_risk", "deduct": 15 },
      { "flag": "unlawful_entry_aos_bar", "deduct": 15 }
    ],
    "thresholds": {
      "petition_ready": 85,
      "review_advised": 60,
      "not_ready": 0
    }
  },

  "output_contract": {
    "consultation_summary": {
      "sections": ["parties", "extraordinary_ability_facts", "scenario_determination", "open_questions"],
      "source_traced": true,
      "editable": true
    },
    "missing_documents_checklist": {
      "groups_by": "document_category",
      "item_states": ["provided", "missing", "needs_supplementation"],
      "source_traced": true,
      "editable": true
    },
    "follow_up_questions": {
      "ordered_by": "fact_priority",
      "generated_from": "missing_required_facts",
      "editable": true
    },
    "intake_completeness_score": {
      "shows_overall": true,
      "shows_dimension_breakdown": true,
      "shows_blocking_flags": true,
      "explainable": true
    }
  }
}
